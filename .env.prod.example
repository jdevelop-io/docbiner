# Domain
DOMAIN=docbiner.com

# PostgreSQL
POSTGRES_USER=docbiner
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=docbiner

# Redis
REDIS_URL=redis://redis:6379

# NATS
NATS_URL=nats://nats:4222

# Minio
MINIO_ROOT_USER=docbiner
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_SECRET
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=docbiner-files

# API
DATABASE_URL=postgresql://docbiner:CHANGE_ME_STRONG_PASSWORD@postgres:5432/docbiner?sslmode=disable
JWT_SECRET=CHANGE_ME_JWT_SECRET
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Worker
CHROMIUM_PATH=/usr/bin/chromium-browser
